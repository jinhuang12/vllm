    # zero_points = torch.randint(0, 255, (batch_size, num_groups), device=device, dtype=torch.uint8)

    # ========================================================================
    # KERNEL INVOCATION: Call wrapper function
    # ========================================================================

    print("Launching kernel...")

    # Warmup (for accurate timing)
    for _ in range(10):
        _ = {{SYMBOL_NAME}}_wrapper(input_tensor)
    torch.cuda.synchronize()

    # Timed execution
    start_event = torch.cuda.Event(enable_timing=True)
    end_event = torch.cuda.Event(enable_timing=True)

    start_event.record()
    output = {{SYMBOL_NAME}}_wrapper(
        input_tensor,
        # Add kernel-specific kwargs here
    )
    end_event.record()
    torch.cuda.synchronize()

    latency_ms = start_event.elapsed_time(end_event)

    # ========================================================================
    # VALIDATION: Check output for correctness
    # ========================================================================

    print(f"Output shape: {output.shape}, dtype: {output.dtype}")

    # Shape validation
    expected_shape = (batch_size, seq_len, hidden_size)  # Adjust as needed
    assert output.shape == expected_shape, (
        f"Shape mismatch: expected {expected_shape}, got {output.shape}"
    )

    # Dtype validation
    assert output.dtype == torch.float16, (
        f"Dtype mismatch: expected float16, got {output.dtype}"
    )

    # NaN/Inf checks
    if torch.isnan(output).any():
        print("⚠ Warning: Output contains NaN values")
    if torch.isinf(output).any():
        print("⚠ Warning: Output contains Inf values")

    # Value range sanity check (kernel-specific)
    # output_min, output_max = output.min().item(), output.max().item()
    # print(f"Output range: [{output_min:.6f}, {output_max:.6f}]")

    print("✓ Validation passed")

    # ========================================================================
    # RETURN: Metadata for benchmarking
    # ========================================================================

    metadata = {
        "batch_size": batch_size,
        "seq_len": seq_len,
        "hidden_size": hidden_size,
        "dtype": str(output.dtype),
        "device": str(output.device),
        "latency_ms": latency_ms,
        "throughput_samples_per_sec": (batch_size * 1000) / latency_ms,
        "memory_mb": (output.numel() * output.element_size()) / (1024 ** 2),
    }

