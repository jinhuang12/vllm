def invocation_example(small: bool = False) -> Tuple[torch.Tensor, Dict[str, Any]]:
    """
    Demonstrate correct usage of the {{SYMBOL_NAME}} kernel.

    This function serves three purposes:
    1. **Documentation**: Shows how to properly invoke the kernel
    2. **Testing**: Validates the bundle works end-to-end
    3. **Benchmarking**: Provides a template for benchmark generation

    Args:
        small: If True, use minimal sizes for quick validation
               If False, use realistic production sizes

    Returns:
        output_tensor: Result from kernel execution
        metadata_dict: Diagnostic information (shapes, dtypes, timing)

    Example:
        >>> # Quick validation
        >>> output, meta = invocation_example(small=True)
        >>> print(f"Output shape: {output.shape}")

        >>> # Production-size test
        >>> output, meta = invocation_example(small=False)
        >>> print(f"Latency: {meta['latency_ms']:.3f} ms")
    """
    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
    assert device.type == "cuda", "This kernel requires CUDA"

    # ========================================================================
    # SETUP PHASE: Create realistic input tensors
    # ========================================================================

    if small:
        # Minimal sizes for quick validation (< 1 second)
        batch_size = 2
        seq_len = 64
        hidden_size = 128
    else:
        # Realistic production sizes for {{MODEL}} on {{HARDWARE}}
        batch_size = 4
        seq_len = 2048
        hidden_size = 4096

