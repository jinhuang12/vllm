    # Create input tensor with appropriate dtype for {{PRECISION}}
    input_tensor = torch.randn(
        batch_size, seq_len, hidden_size,
        dtype=torch.float16,  # Adjust for {{PRECISION}}
        device=device,
        requires_grad=False  # CRITICAL: No gradient tracking in benchmarks
    )

